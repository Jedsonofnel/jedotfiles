#!/usr/bin/env python3
# JEDN jn-theme-generate
# Reads base16 YAML files from jedotfiles/themes/ and generates:
#   - jedotfiles/xdg_config/nvim/colors/jn_<name>.lua
#   - jedotfiles/xdg_config/ghostty/themes/jn_<name>
# Run after adding new YAML files. Outputs are checked into git.

import os
import sys
from pathlib import Path

# Resolve real path through stow symlink -> jedotfiles root
DOTFILES   = Path(os.path.realpath(__file__)).parent.parent
THEMES_DIR = DOTFILES / "themes"
NVIM_DIR   = DOTFILES / "xdg_config" / "nvim" / "colors"
GHOSTTY_DIR = DOTFILES / "xdg_config" / "ghostty" / "themes"

# Standard base16 -> ANSI terminal palette mapping
BASE16_ANSI = [
    "base00",  # 0  black
    "base08",  # 1  red
    "base0B",  # 2  green
    "base0A",  # 3  yellow
    "base0D",  # 4  blue
    "base0E",  # 5  magenta
    "base0C",  # 6  cyan
    "base05",  # 7  white
    "base03",  # 8  bright black
    "base08",  # 9  bright red
    "base0B",  # 10 bright green
    "base0A",  # 11 bright yellow
    "base0D",  # 12 bright blue
    "base0E",  # 13 bright magenta
    "base0C",  # 14 bright cyan
    "base07",  # 15 bright white
]

BASE16_KEYS = [
    "base00", "base01", "base02", "base03",
    "base04", "base05", "base06", "base07",
    "base08", "base09", "base0A", "base0B",
    "base0C", "base0D", "base0E", "base0F",
]


def parse_yaml(path):
    """Minimal key: value YAML parser — sufficient for base16 scheme files."""
    meta, palette = {}, {}
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            key, _, value = line.partition(":")
            key   = key.strip()
            value = value.strip().strip('"').strip("'").lstrip("#")
            if key.startswith("base"):
                palette[key] = "#" + value
            else:
                meta[key] = value
    return meta, palette


def nvim_theme(name, meta, palette):
    scheme_name = f"jn_{name}"
    header = "\n".join([
        f"-- {NVIM_DIR}/{scheme_name}.lua",
        f"-- {meta.get('scheme', name)} | {meta.get('author', 'unknown')}",
        "-- Generated by jn-theme-generate — do not edit directly",
    ])
    palette_lines = "\n".join(
        f"    {k} = '{palette.get(k, '#000000')}',"
        for k in BASE16_KEYS
    )
    return f"""{header}

vim.g.colors_name = '{scheme_name}'

require('mini.base16').setup({{
  palette = {{
{palette_lines}
  }},
  use_cterm = true,
  plugins = {{
    default = false,
    ['nvim-mini/mini.nvim'] = true,
  }},
}})
"""


def ghostty_theme(name, meta, palette):
    header = "\n".join([
        f"# {meta.get('scheme', name)} | {meta.get('author', 'unknown')}",
        "# Generated by jn-theme-generate — do not edit directly",
    ])
    bg  = palette.get("base00", "#000000").lstrip("#")
    fg  = palette.get("base05", "#ffffff").lstrip("#")
    sel = palette.get("base02", "#333333").lstrip("#")
    palette_lines = "\n".join(
        f"palette = {i}={palette.get(key, '#000000')}"
        for i, key in enumerate(BASE16_ANSI)
    )
    return f"""{header}
background = {bg}
foreground = {fg}
cursor-color = {fg}
selection-background = {sel}
selection-foreground = {fg}
{palette_lines}
"""


def main():
    NVIM_DIR.mkdir(parents=True, exist_ok=True)
    GHOSTTY_DIR.mkdir(parents=True, exist_ok=True)

    yaml_files = sorted(THEMES_DIR.glob("*.yaml")) + sorted(THEMES_DIR.glob("*.yml"))
    if not yaml_files:
        print(f"No YAML files found in {THEMES_DIR}", file=sys.stderr)
        sys.exit(1)

    for path in yaml_files:
        name = path.stem
        meta, palette = parse_yaml(path)

        nvim_path = NVIM_DIR / f"jn_{name}.lua"
        nvim_path.write_text(nvim_theme(name, meta, palette))

        ghostty_path = GHOSTTY_DIR / f"jn_{name}"
        ghostty_path.write_text(ghostty_theme(name, meta, palette))

        print(f"  {name}")
        print(f"    nvim    → {nvim_path.relative_to(DOTFILES)}")
        print(f"    ghostty → {ghostty_path.relative_to(DOTFILES)}")

    print(f"\n{len(yaml_files)} theme(s) generated.")


if __name__ == "__main__":
    main()
