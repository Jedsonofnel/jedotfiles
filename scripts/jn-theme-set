#!/usr/bin/env python3
# JEDN jn-theme-set
# Usage: jn-theme-set [theme-name]
# Without argument: picks via fzf from available themes in jedotfiles/themes/
# Updates:
#   - $XDG_CONFIG_HOME/ghostty/config  (theme = line)
#   - $XDG_CONFIG_HOME/nvim/init.lua   (vim.cmd.colorscheme line)
# Then reloads ghostty. Neovim picks it up on next start (or :colorscheme jn_X live).

import os
import re
import sys
import subprocess
from pathlib import Path

DOTFILES   = Path(os.path.realpath(__file__)).parent.parent
THEMES_DIR = DOTFILES / "themes"

XDG = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
GHOSTTY_CONFIG = XDG / "ghostty" / "config"
NVIM_CONFIG    = XDG / "nvim" / "init.lua"


def available_themes():
    files = sorted(THEMES_DIR.glob("*.yaml")) + sorted(THEMES_DIR.glob("*.yml"))
    return [f.stem for f in files]


def pick_theme(themes):
    # Strip jn_ prefix if user passed it
    if len(sys.argv) > 1:
        name = sys.argv[1].removeprefix("jn_")
        if name not in themes:
            print(f"Unknown theme: {name}", file=sys.stderr)
            print("Available: " + ", ".join(themes), file=sys.stderr)
            sys.exit(1)
        return name

    # Fall back to fzf
    try:
        result = subprocess.run(
            ["fzf", "--prompt", "theme > ", "--height", "40%"],
            input="\n".join(themes),
            capture_output=True,
            text=True,
        )
        name = result.stdout.strip()
        if not name:
            sys.exit(0)
        return name.removeprefix("jn_")
    except FileNotFoundError:
        print("fzf not found. Usage: jn-theme-set <theme-name>", file=sys.stderr)
        print("Available: " + ", ".join(themes), file=sys.stderr)
        sys.exit(1)


def update_ghostty(scheme_name):
    text    = GHOSTTY_CONFIG.read_text()
    new_line = f"theme = jn_{scheme_name}"
    if re.search(r"^theme\s*=", text, re.MULTILINE):
        text = re.sub(r"^theme\s*=.*$", new_line, text, flags=re.MULTILINE)
    else:
        text = text.rstrip() + f"\n{new_line}\n"
    GHOSTTY_CONFIG.write_text(text)
    print(f"  ghostty → {new_line}")


def update_nvim(scheme_name):
    text     = NVIM_CONFIG.read_text()
    new_line = f'vim.cmd.colorscheme("jn_{scheme_name}")'
    if re.search(r"^vim\.cmd\.colorscheme\(", text, re.MULTILINE):
        text = re.sub(
            r'^vim\.cmd\.colorscheme\(.*\)$',
            new_line,
            text,
            flags=re.MULTILINE,
        )
    else:
        text = text.rstrip() + f"\n{new_line}\n"
    NVIM_CONFIG.write_text(text)
    print(f"  nvim    → {new_line}")


def reload_ghostty():
    try:
        result = subprocess.run(
            ["ghostty", "+reload-config"],
            capture_output=True,
            text=True,
        )
        if result.returncode == 0:
            print("  ghostty reloaded")
        else:
            print("  ghostty reload failed — restart manually (ctrl+shift+,)")
    except FileNotFoundError:
        print("  ghostty not in PATH — restart to apply")


def main():
    themes = available_themes()
    if not themes:
        print(f"No themes found in {THEMES_DIR}", file=sys.stderr)
        sys.exit(1)

    name = pick_theme(themes)

    print(f"\nSetting theme: jn_{name}")
    update_ghostty(name)
    update_nvim(name)
    reload_ghostty()
    print(f"\nDone. Neovim: :colorscheme jn_{name} to apply in running session.")


if __name__ == "__main__":
    main()
